// strlen.jav
class strlen {
    public static void main() {
        String str = "Hello World!";
        int len1 = str.length();
        int len2 = "Hello".length();

        System.out.println(str);   // "Hello World!"
        System.out.println(len1);  // 12
        System.out.println(len2);  // 5
    }
}
